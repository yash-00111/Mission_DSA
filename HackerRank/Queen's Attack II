#include <bits/stdc++.h>
using namespace std;

int queensAttack(int n, int k, int r_q, int c_q, vector<vector<int>> obstacles) {
    int up = n - r_q;
    int down = r_q - 1;
    int right = n - c_q;
    int left = c_q - 1;

    int ur = min(up, right);
    int ul = min(up, left);
    int dr = min(down, right);
    int dl = min(down, left);

    for (auto &o : obstacles) {
        int r = o[0], c = o[1];

        if (c == c_q) {
            if (r > r_q) up = min(up, r - r_q - 1);
            else down = min(down, r_q - r - 1);
        }
        else if (r == r_q) {
            if (c > c_q) right = min(right, c - c_q - 1);
            else left = min(left, c_q - c - 1);
        }
        else if (abs(r - r_q) == abs(c - c_q)) {
            if (r > r_q && c > c_q)
                ur = min(ur, r - r_q - 1);
            else if (r > r_q && c < c_q)
                ul = min(ul, r - r_q - 1);
            else if (r < r_q && c > c_q)
                dr = min(dr, r_q - r - 1);
            else
                dl = min(dl, r_q - r - 1);
        }
    }

    return up + down + left + right + ur + ul + dr + dl;
}
